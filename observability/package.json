{
  "name": "gal-observability",
  "version": "1.0.1",
  "description": "OpenTelemetry bootstrap utilities for the Gal ecosystem.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./fastify": {
      "types": "./dist/fastify/index.d.ts",
      "default": "./dist/fastify/index.js"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "default": "./dist/logger/index.js"
    },
    "./open-telemetry": {
      "types": "./dist/open-telemetry/index.d.ts",
      "default": "./dist/open-telemetry/index.js"
    }
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "npx eslint . --fix",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "opentelemetry",
    "observability",
    "logging",
    "pino",
    "fastify",
    "tracing"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "Tal Finkelshtein",
  "license": "ISC",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.208.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.208.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/instrumentation": "^0.208.0",
    "@opentelemetry/instrumentation-amqplib": "^0.55.0",
    "@opentelemetry/instrumentation-aws-sdk": "^0.62.0",
    "@opentelemetry/instrumentation-http": "^0.208.0",
    "@opentelemetry/instrumentation-mongodb": "^0.61.0",
    "@opentelemetry/instrumentation-redis-4": "^0.46.1",
    "@opentelemetry/instrumentation-runtime-node": "^0.22.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.208.0",
    "fastify-plugin": "^5.1.0",
    "pino": "^10.3.1"
  },
  "peerDependencies": {
    "fastify": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.9",
    "@types/split2": "^4.2.3",
    "eslint": "^9.39.2",
    "fastify": "^5.7.1",
    "rimraf": "^6.1.3",
    "split2": "^4.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.2.7"
  }
}
