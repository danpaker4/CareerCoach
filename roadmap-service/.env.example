PORT=3005
HOST=0.0.0.0
MONGO_CONNECTION_STRING=mongodb://127.0.0.1:27017/careerCoachDB
MONGO_KEY_PATH=none
USERS_SERVICE_BASE_URL=http://127.0.0.1:3001
JOB_SERVICE_BASE_URL=http://127.0.0.1:3003
CHAT_SERVICE_BASE_URL=http://127.0.0.1:3002
INTERNAL_SERVICE_API_KEY=local-dev-internal-service-key

LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
# Basic auth for gateways that need it, format user:password (e.g. college LLM service)
LLM_BASIC_AUTH=
# OpenAI-compatible base URL override (default https://api.openai.com)
OPENAI_BASE_URL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

CUSTOM_LLM_URL=
EMBEDDING_MODEL=text-embedding-004
CUSTOM_EMBEDDING_URL=
CAREER_DIRECTION_VECTOR_INDEX_NAME=career_direction_vector_index

OTEL_ENABLED=false
OTEL_SERVICE_NAME=careercoach.roadmap-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_DEPLOYMENT_ENVIRONMENT=local
