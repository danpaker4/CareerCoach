# Production template for the college VM. Copy to roadmap-service.env (never commit) and fill secrets.
PORT=3005
HOST=0.0.0.0
NODE_ENV=production

MONGO_CONNECTION_STRING=mongodb://admin:<mongo-password-url-encoded>@host.docker.internal:21771/careerCoachDB?authSource=admin&directConnection=true
MONGO_KEY_PATH=none

USERS_SERVICE_BASE_URL=http://users-service:3001
JOB_SERVICE_BASE_URL=http://job-service:3003
CHAT_SERVICE_BASE_URL=http://chat-service:3002
INTERNAL_SERVICE_API_KEY=

# College LLM service (Basic Auth). Fallback chain: ollama -> gemini (if key) -> custom.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://llm.cs.colman.ac.il
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=120000
LLM_BASIC_AUTH=
GEMINI_API_KEY=
GEMINI_MODEL=
CUSTOM_LLM_URL=
OPENAI_BASE_URL=

# Embeddings via college /api/embed (all-minilm = 384-dim)
EMBEDDING_MODEL=all-minilm:latest
CUSTOM_EMBEDDING_URL=http://llm.cs.colman.ac.il/api/embed
CAREER_DIRECTION_VECTOR_INDEX_NAME=career_direction_vector_index

OTEL_ENABLED=false
