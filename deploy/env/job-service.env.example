# Production template for the college VM. Copy to job-service.env (never commit) and fill secrets.
PORT=3003
HOST=0.0.0.0
NODE_ENV=production

MONGO_CONNECTION_STRING=mongodb://admin:<mongo-password-url-encoded>@host.docker.internal:21771/careerCoachDB?authSource=admin&directConnection=true
MONGO_KEY_PATH=none

USERS_SERVICE_BASE_URL=http://users-service:3001
INTERNAL_SERVICE_API_KEY=

# College LLM service (Basic Auth).
# Use the raw IP: the gateway nginx 403s Host: llm.cs.colman.ac.il (only the IP vhost
# is served — the integration guide lists http://10.10.248.41 as the primary HTTP URL).
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://10.10.248.41
OLLAMA_MODEL=llama3.1:8b
LLM_MODEL=llama3.1:8b
LLM_BASIC_AUTH=
GEMINI_API_KEY=

# Embeddings via college /api/embed (all-minilm = 384-dim)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=all-minilm:latest

# Job poller is currently disabled in code; key kept for future use.
THEIRSTACK_API_KEY=

OTEL_ENABLED=false
