# Production template for the college VM. Copy to users-service.env (never commit) and fill secrets.
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# VM host MongoDB (port 21771). URL-encode special chars in the password (@ -> %40).
MONGO_CONNECTION_STRING=mongodb://admin:<mongo-password-url-encoded>@host.docker.internal:21771/careerCoachDB?authSource=admin&directConnection=true
MONGO_KEY_PATH=none

# College LLM service (Basic Auth). LLM_BASIC_AUTH format: user:password
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://llm.cs.colman.ac.il
OLLAMA_MODEL=llama3.1:8b
LLM_MODEL=llama3.1:8b
LLM_BASIC_AUTH=
# Optional Gemini fallback (leave empty to disable)
GEMINI_API_KEY=
GEMINI_MODEL=

# Embeddings via college /api/embed (all-minilm = 384-dim)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=all-minilm:latest

# Auth — generate fresh random values (openssl rand -hex 32)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=604800
REFRESH_TOKEN_COOKIE=refreshToken
# Must match all other services
INTERNAL_SERVICE_API_KEY=

# MinIO (compose service). Credentials must match MINIO_ROOT_USER/PASSWORD in the compose .env.
S3_BUCKET=careercoach-uploads
S3_REGION=us-east-1
S3_ENDPOINT=http://minio:9000
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_UPLOAD_PREFIX=uploads

# GitHub OAuth app (callback must point at https://careercoach.cs.colman.ac.il)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

OTEL_ENABLED=false
