# Production template for the college VM. Copy to evaluation-service.env (never commit) and fill secrets.
PORT=3004
HOST=0.0.0.0
NODE_ENV=production

MONGO_CONNECTION_STRING=mongodb://admin:<mongo-password-url-encoded>@host.docker.internal:21771/careerCoachDB?authSource=admin&directConnection=true

CHAT_SERVICE_BASE_URL=http://chat-service:3002
EVALUATION_USER_ID=evaluation-runner-user
INTERNAL_SERVICE_API_KEY=
