# Production template for the college VM. Copy to chat-service.env (never commit) and fill secrets.
# Used by both chat-service and chat-worker containers.
PORT=3002
HOST=0.0.0.0
NODE_ENV=production

MONGO_CONNECTION_STRING=mongodb://admin:<mongo-password-url-encoded>@host.docker.internal:21771/careerCoachDB?authSource=admin&directConnection=true
MONGO_KEY_PATH=none

# Compose-internal service DNS
USERS_SERVICE_BASE_URL=http://users-service:3001
JOB_SERVICE_BASE_URL=http://job-service:3003
ROADMAP_SERVICE_BASE_URL=http://roadmap-service:3005
RABBITMQ_URL=amqp://rabbitmq:5672
CHAT_REQUEST_QUEUE_NAME=chat.message.requests
CHAT_EVENTS_EXCHANGE_NAME=chat.request.events
INTERNAL_SERVICE_API_KEY=

# College LLM service (Basic Auth). Fallback chain: ollama -> gemini (if key) -> custom.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://llm.cs.colman.ac.il
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=120000
LLM_BASIC_AUTH=
GEMINI_API_KEY=
GEMINI_MODEL=
CUSTOM_LLM_URL=
# Opt-in gpt-oss-120b: set OPENAI_BASE_URL=http://llm.cs.colman.ac.il and LLM_PROVIDER=openai
OPENAI_BASE_URL=

# Embeddings via college /api/embed (all-minilm = 384-dim)
EMBEDDING_MODEL=all-minilm:latest
CUSTOM_EMBEDDING_URL=http://llm.cs.colman.ac.il/api/embed
CAREER_PROFILE_VECTOR_INDEX_NAME=career_profile_vector_index
CAREER_DIRECTION_VECTOR_INDEX_NAME=career_direction_vector_index

OTEL_ENABLED=false
