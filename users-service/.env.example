PORT=3001
HOST=0.0.0.0
MONGO_CONNECTION_STRING=mongodb://127.0.0.1:27017/careerCoachDB
MONGO_KEY_PATH=none
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.0-flash
GEMINI_MODEL=gemini-3.0-flash
GEMINI_API_KEY=
JWT_ACCESS_SECRET=veryVerySecret
JWT_REFRESH_SECRET=notSoSecret
JWT_ACCESS_EXPIRES_IN_SECONDS=60
JWT_REFRESH_EXPIRES_IN_SECONDS=604800
# Must match chat-service INTERNAL_SERVICE_API_KEY for server-to-server dream job saves.
INTERNAL_SERVICE_API_KEY=local-dev-internal-service-key
REFRESH_TOKEN_COOKIE=refreshToken
S3_BUCKET=video-editor
S3_REGION=us-east-1
S3_ENDPOINT=http://127.0.0.1:9000
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin123
S3_UPLOAD_PREFIX=uploads
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OpenTelemetry tracing (optional)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_DEPLOYMENT_ENVIRONMENT=local
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
