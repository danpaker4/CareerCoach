# Evaluation-service that Promptfoo calls (must have cases seeded)
EVALUATION_SERVICE_BASE_URL=http://127.0.0.1:3004

# Optional second evaluation-service / chat stack for A/B comparison
CANDIDATE_EVALUATION_SERVICE_BASE_URL=http://127.0.0.1:3004

# Judge model for optional llm-rubric assertions (no secrets here — use provider env vars)
PROMPTFOO_JUDGE_PROVIDER=openai
PROMPTFOO_JUDGE_MODEL=gpt-4o-mini
PROMPTFOO_ENABLE_JUDGE=false

# Promptfoo run tuning
PROMPTFOO_PASS_THRESHOLD=0.8
PROMPTFOO_MAX_CONCURRENCY=1
PROMPTFOO_TIMEOUT_MS=1200000

# Provider API keys for the judge (set in your local .env, never commit)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_BASE=
