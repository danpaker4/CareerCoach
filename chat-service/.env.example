PORT=3002
HOST=0.0.0.0
MONGO_CONNECTION_STRING=mongodb://127.0.0.1:27017/careerCoachDB
MONGO_KEY_PATH=none
USERS_SERVICE_BASE_URL=http://127.0.0.1:3001
# Same value as users-service CHAT_INTERNAL_API_KEY; sent as X-Career-Coach-Internal-Key so PATCH works when user JWT is short-lived
USERS_SERVICE_INTERNAL_API_KEY=
JOB_SERVICE_BASE_URL=http://127.0.0.1:3003

# LLM_PROVIDER: gemini | openai | custom | ollama
LLM_PROVIDER=ollama
GEMINI_API_KEY=
LLM_MODEL=llama3

# When LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# When LLM_PROVIDER=custom — POST JSON { "prompt": "..." }, response JSON with text|reply|content
CUSTOM_LLM_URL=

# When LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:9009
OLLAMA_MODEL=llama3

# Embeddings
EMBEDDING_MODEL=text-embedding-004
CUSTOM_EMBEDDING_URL=
CONVERSATION_MEMORY_VECTOR_INDEX_NAME=conversation_memory_vector_index
CAREER_PROFILE_VECTOR_INDEX_NAME=career_profile_vector_index
CAREER_DIRECTION_VECTOR_INDEX_NAME=career_direction_vector_index
