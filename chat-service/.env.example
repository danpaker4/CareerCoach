PORT=3002
HOST=0.0.0.0
MONGO_CONNECTION_STRING=mongodb://127.0.0.1:27017/careerCoachDB
MONGO_KEY_PATH=none
USERS_SERVICE_BASE_URL=http://127.0.0.1:3001
JOB_SERVICE_BASE_URL=http://127.0.0.1:3003
ROADMAP_SERVICE_BASE_URL=http://127.0.0.1:3005
RABBITMQ_URL=amqp://127.0.0.1:5672
CHAT_REQUEST_QUEUE_NAME=chat.message.requests
CHAT_EVENTS_EXCHANGE_NAME=chat.request.events
# Shared with users-service; lets chat-service save dream jobs when forwarding the user JWT fails.
INTERNAL_SERVICE_API_KEY=local-dev-internal-service-key

# Gateway mode (default): Dify + LiteLLM work together.
# - With DIFY_API_KEY set: chain is [dify, litellm] (Dify first, LiteLLM fallback).
# - Without DIFY_API_KEY: LiteLLM alone handles chat (until you create a Dify app key).
# - Inside Dify UI, point the model provider at LiteLLM (see README).
# Escape hatch: set LLM_PROVIDER to ollama|gemini|custom to bypass both gateways.
LLM_PROVIDER=litellm
LITELLM_BASE_URL=http://127.0.0.1:4000
LITELLM_API_KEY=sk-litellm-local-dev
LITELLM_MODEL=chat-default

# Dify (bundled via npm run infra:up — separate compose project on :8088)
DIFY_API_BASE_URL=http://127.0.0.1:8088/v1
DIFY_API_KEY=

# Escape-hatch direct providers (used when LLM_PROVIDER is ollama|gemini|custom)
OLLAMA_BASE_URL=http://127.0.0.1:9009
OLLAMA_MODEL=llama3
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CUSTOM_LLM_URL=

# Embeddings
EMBEDDING_MODEL=text-embedding-004
CUSTOM_EMBEDDING_URL=
CAREER_PROFILE_VECTOR_INDEX_NAME=career_profile_vector_index
CAREER_DIRECTION_VECTOR_INDEX_NAME=career_direction_vector_index

# OpenTelemetry tracing (optional, Jaeger via otel-collector)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_DEPLOYMENT_ENVIRONMENT=local
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# Langfuse LLM observability (self-hosted UI at http://localhost:3100)
LANGFUSE_PUBLIC_KEY=pk-lf-local-dev
LANGFUSE_SECRET_KEY=sk-lf-local-dev
LANGFUSE_BASE_URL=http://127.0.0.1:3100
